// Philippine Lottery Prediction Database Schema
// Provider: sqlserver for local dev, postgresql for cloud deployment
// When switching provider, also toggle numbers column type (String for sqlserver, Int[] for postgresql)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model LotteryGame {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  maxNumber   Int
  numberCount Int
  createdAt   DateTime @default(now())

  results     LotteryResult[]
  predictions Prediction[]

  @@map("lottery_games")
}

model LotteryResult {
  id         String   @id @default(cuid())
  gameId     String
  drawDate   DateTime
  numbers    String   // Comma-separated winning numbers (e.g. "1,7,14,22,35,42")
  jackpot    Decimal? @db.Decimal(15, 2)
  createdAt  DateTime @default(now())

  game       LotteryGame @relation(fields: [gameId], references: [id])

  @@unique([gameId, drawDate])
  @@map("lottery_results")
}

model Prediction {
  id           String   @id @default(cuid())
  gameId       String
  predictedFor DateTime
  numbers      String   // Comma-separated predicted numbers (e.g. "3,11,19,28,36,41")
  algorithm    String
  confidence   Float?
  createdAt    DateTime @default(now())

  game         LotteryGame @relation(fields: [gameId], references: [id])

  @@map("predictions")
}

model NumberStatistics {
  id           String   @id @default(cuid())
  gameId       String
  number       Int
  frequency    Int      @default(0)
  lastDrawn    DateTime?
  coldStreak   Int      @default(0)
  hotStreak    Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([gameId, number])
  @@map("number_statistics")
}
